    "sqlite-vec": "^0.1.6",
    "commander": "^13.1.0",
    "@xenova/transformers": "^2.17.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "yaml": "^2.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.3",
    "tsup": "^8.3.6",
    "vitest": "^3.0.5",
    "eslint": "^9.19.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0"
  },
